{
  "rules": {
    "presence": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "chats": {
      "$chatId": {
        ".read":  "auth != null && data.child('participants').child(auth.uid).exists()",
        ".write": "auth != null",
        "messages": {
          "$messageId": {
            ".read": "auth != null",
            ".write": "auth != null",
            ".validate": "newData.hasChildren(['senderId', 'timestamp'])"
          }
        }
      }
    },
    "channels": {
      ".read": "auth != null",
      "$channelId": { ".write": "auth != null" }
    },
    "notifications": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null"
      }
    },
    "pointsAlerts": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null"
      }
    },
    "typingIndicators": {
      "$chatId": {
        ".read":  "auth != null",
        ".write": "auth != null"
      }
    },
    "liveCounters": {
      ".read":  true,
      ".write": "auth != null"
    }
  }
}
