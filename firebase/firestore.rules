// =============================================================================
// firebase/firestore.rules
// Deploy from Firebase Console → Firestore → Rules → paste the contents of this file.
// Mirrors src/firebase/rules/firestore.rules — kept here so the deploy bundle
// is self-contained at the repo root.
// =============================================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth()  { return request.auth != null; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }
    function isAdmin() { return isAuth() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isEmailVerified() { return isAuth() && request.auth.token.email_verified == true; }

    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
      match /followers/{followerId} { allow read: if true; allow write: if isAuth(); }
      match /following/{followingId} { allow read: if true; allow write: if isOwner(userId); }
      match /bookmarks/{postId} { allow read, write: if isOwner(userId); }
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuth() && isEmailVerified();
      allow update: if isOwner(resource.data.authorId) || isAdmin();
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
      match /likes/{userId} { allow read: if true; allow write: if isOwner(userId); }
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isOwner(resource.data.authorId) || isAdmin();
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.recipientId == request.auth.uid;
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.recipientId == request.auth.uid;
      allow delete: if isAuth() && resource.data.recipientId == request.auth.uid;
    }

    match /pointsTransactions/{txId} {
      allow read: if isAuth() && (
        resource.data.fromUserId == request.auth.uid ||
        resource.data.toUserId   == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    match /admins/{adminId} { allow read, write: if isAdmin(); }

    match /verificationRequests/{reqId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    match /systemSettings/{doc} { allow read: if true; allow write: if isAdmin(); }
    match /seoSettings/{doc}    { allow read: if true; allow write: if isAdmin(); }

    match /communities/{communityId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth() && (resource.data.adminId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
      match /members/{memberId} { allow read: if true; allow write: if isAuth(); }
    }

    match /ads/{adId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isOwner(resource.data.advertiserId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /courses/{courseId}      { allow read: if true; allow write: if isAdmin(); }
    match /certificates/{certId}   { allow read: if true; allow create: if isAuth(); allow update, delete: if isAdmin(); }
    match /channels/{channelId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth() && (resource.data.adminId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }
  }
}
