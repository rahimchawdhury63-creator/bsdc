// =============================================================================
// BSDC — Firestore Security Rules
// =============================================================================
// Deploy via Firebase Console (Firestore → Rules) or `firebase deploy --only firestore:rules`
// We intentionally keep the rules verbose & well-commented so any future
// contributor understands the security model at a glance.
// =============================================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helper functions ----------
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isAuth() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isEmailVerified() {
      return isAuth() && request.auth.token.email_verified == true;
    }

    // ---------- users ----------
    // Profiles are PUBLIC reads (needed for SEO crawling profile pages).
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      // Sub-collections: followers / following
      match /followers/{followerId} {
        allow read: if true;
        allow write: if isAuth();
      }
      match /following/{followingId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
    }

    // ---------- posts ----------
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuth() && isEmailVerified();
      allow update: if isOwner(resource.data.authorId) || isAdmin();
      allow delete: if isOwner(resource.data.authorId) || isAdmin();

      // Likes sub-collection — one doc per user that liked.
      match /likes/{userId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
    }

    // ---------- comments ----------
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isOwner(resource.data.authorId) || isAdmin();
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }

    // ---------- notifications (private to recipient) ----------
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.recipientId == request.auth.uid;
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.recipientId == request.auth.uid;
      allow delete: if isAuth() && resource.data.recipientId == request.auth.uid;
    }

    // ---------- points transactions ----------
    match /pointsTransactions/{txId} {
      allow read: if isAuth() && (
        resource.data.fromUserId == request.auth.uid ||
        resource.data.toUserId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ---------- admins (only admins can read) ----------
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ---------- verification requests ----------
    match /verificationRequests/{reqId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ---------- system + SEO settings (public read, admin write) ----------
    match /systemSettings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /seoSettings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------- communities ----------
    match /communities/{communityId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth() && (resource.data.adminId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();

      match /members/{memberId} {
        allow read: if true;
        allow write: if isAuth();
      }
    }

    // ---------- ads ----------
    match /ads/{adId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isOwner(resource.data.advertiserId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ---------- courses + certificates ----------
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /certificates/{certId} {
      allow read: if true;          // public verification page needs read
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ---------- channels (Telegram-style; admin posts only) ----------
    match /channels/{channelId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth() && (resource.data.adminId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
